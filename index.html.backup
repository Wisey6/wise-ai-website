<!doctype html>
<html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><title>Wise Ai</title><link href="https://fonts.googleapis.com/css2?family=Archivo:wght@900&display=swap" rel="stylesheet"><style>*{margin:0;padding:0;box-sizing:border-box}body{font-family:Archivo,sans-serif}section{min-height:100vh;background:#FF4D00;color:#1A1A1A;padding:60px 40px;display:flex}div.wrap{max-width:1360px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center;flex:1;width:100%}h1{font-size:140px;font-weight:900;line-height:0.9;margin-bottom:30px}p{font-size:22px;margin-bottom:40px;max-width:500px}div.btns{display:flex;gap:20px}button{padding:16px 32px;font-size:16px;border-radius:999px;border:none;cursor:pointer;font-weight:600}.p{background:#1A1A1A;color:white}.p:hover{background:#FAFAFA;color:#1A1A1A}.g{background:0;border:2px solid #1A1A1A}.g:hover{background:#1A1A1A;color:white}div.c3d{height:500px}div.st{position:fixed;bottom:20px;left:20px;font-size:12px;font-family:monospace;background:rgba(0,0,0,0.1);padding:10px;border-radius:6px}@media(max-width:900px){div.wrap{grid-template-columns:1fr}h1{font-size:80px}div.c3d{height:300px}}</style></head><body><section><div class="wrap"><div><h1>WISE<br><span style="font-size:0.35em">Ai</span></h1><p>AI that saves your team hours, not headlines.</p><div class="btns"><button class="p">See services</button><button class="g">Book a call</button></div></div><div class="c3d" id="c3d"></div></div></section><div class="st" id="st">Loading...</div><script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script><script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/GLTFLoader.min.js"></script><script>const st=document.getElementById('st'),ct=document.getElementById('c3d'),w=ct.clientWidth,h=ct.clientHeight;if(!w||!h){st.textContent='Container error';} else {const sc=new THREE.Scene(),cm=new THREE.PerspectiveCamera(50,w/h,0.1,1000),rn=new THREE.WebGLRenderer({antialias:!0,alpha:!0});rn.setSize(w,h);rn.setClearColor(0xFF6600,0);rn.shadowMap.enabled=!0;rn.outputColorSpace=THREE.SRGBColorSpace;rn.toneMapping=THREE.ACESFilmicToneMapping;cm.position.set(0,0.5,2.2);cm.lookAt(0,0.2,0);ct.appendChild(rn.domElement);sc.add(new THREE.AmbientLight(0xffffff,0.5));const kl=new THREE.DirectionalLight(0xffffff,1.2);kl.position.set(4,6,3);kl.castShadow=!0;kl.shadow.mapSize.width=2048;kl.shadow.mapSize.height=2048;sc.add(kl);sc.add(new THREE.DirectionalLight(0x87ceeb,0.4));let md=null;st.textContent='Loading MacBook...';new THREE.GLTFLoader().load('scene.gltf',t=>{md=t.scene;md.traverse(e=>{if(e.isMesh){e.castShadow=!0;e.receiveShadow=!0}});sc.add(md);st.textContent='Ready'},t=>{st.textContent='Loading '+Math.round(100*t.loaded/t.total)+'%'},t=>{st.textContent='Error loading';console.error(t)});let mx=0,my=0,rx=0,ry=0,dn=!1,zm=2.2;document.addEventListener('mousedown',t=>{dn=!0;mx=t.clientX;my=t.clientY});document.addEventListener('mousemove',t=>{if(dn&&md){ry+=(t.clientX-mx)*0.005;rx+=(t.clientY-my)*0.005;mx=t.clientX;my=t.clientY}});document.addEventListener('mouseup',()=>{dn=!1});document.addEventListener('wheel',t=>{t.preventDefault();zm=Math.max(1,Math.min(4,zm+0.001*t.deltaY));cm.position.z=zm},{passive:!1});function an(){if(md){md.rotation.y+=(ry-md.rotation.y)*0.1;md.rotation.x+=(rx-md.rotation.x)*0.1;if(!dn)md.rotation.y+=0.0008}rn.render(sc,cm);requestAnimationFrame(an)}an();window.addEventListener('resize',()=>{const t=ct.clientWidth,e=ct.clientHeight;cm.aspect=t/e;cm.updateProjectionMatrix();rn.setSize(t,e)})}</script></body></html>
